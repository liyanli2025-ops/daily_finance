# ==========================================
# 财经日报系统配置文件示例
# 复制此文件为 .env 并填入你的配置
# ==========================================

# -------------------------------------------
# 👤 用户个性化配置（强烈建议配置）
# -------------------------------------------

# 用户昵称（播客中会用这个称呼你）
USER_NICKNAME=卢卡

# 投资风格（影响分析角度和建议激进程度）
# conservative = 保守型（偏好低风险、稳健收益）
# balanced = 平衡型（风险收益均衡）
# aggressive = 激进型（追求高收益，能承受波动）
INVESTMENT_STYLE=balanced

# 自选股列表（会在每日报告中特别追踪分析！）
# 格式: 代码:名称:市场（多个用逗号分隔）
# 市场: A=A股, HK=港股
# 
# 示例：追踪茅台、腾讯、宁德时代
# WATCHLIST_STOCKS=600519:贵州茅台:A,00700:腾讯控股:HK,300750:宁德时代:A
#
# 更多示例：
# 科技股组合：300750:宁德时代:A,002594:比亚迪:A,00700:腾讯控股:HK
# 消费股组合：600519:贵州茅台:A,000858:五粮液:A,600887:伊利股份:A
# 港股组合：00700:腾讯控股:HK,09988:阿里巴巴:HK,03690:美团:HK
WATCHLIST_STOCKS=

# -------------------------------------------
# 🤖 AI 服务配置（选择一种即可）
# -------------------------------------------

# 方式1：使用 Claude（推荐，分析质量最佳）
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# 方式2：使用 GPT-4（OpenAI 官方）
# OPENAI_API_KEY=sk-xxxxx
# AI_MODEL=gpt-4-turbo

# 方式3：使用 DeepSeek（高性价比，效果接近 GPT-4）
# OPENAI_API_KEY=sk-xxxxx  # DeepSeek 的 API Key
# OPENAI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# 方式4：使用其他 OpenAI 兼容服务（如硅基流动、智谱等）
# OPENAI_API_KEY=你的key
# OPENAI_BASE_URL=服务商的base_url
# AI_MODEL=对应的模型名

# 方式5：不配置任何 key（默认）
# 系统会自动使用免费的 Pollinations.AI 服务
# 注意：免费服务不稳定，仅建议用于测试

# -------------------------------------------
# 📊 股票数据配置（可选）
# -------------------------------------------

# Tushare Token（可选，AKShare 已经够用）
# TUSHARE_TOKEN=your_token_here

# -------------------------------------------
# ⏰ 定时任务配置
# -------------------------------------------

# 每日报告推送时间（24小时制）
DAILY_REPORT_HOUR=7
DAILY_REPORT_MINUTE=0

# 新闻采集提前时间（分钟）
COLLECTION_LEAD_TIME=60

# -------------------------------------------
# 🎙️ 语音合成配置（播客功能）
# -------------------------------------------

# TTS 语音角色
# 可选：zh-CN-YunxiNeural（男声）、zh-CN-XiaoxiaoNeural（女声）
TTS_VOICE=zh-CN-YunxiNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# -------------------------------------------
# ⚙️ 服务器配置
# -------------------------------------------

DEBUG=true
HOST=0.0.0.0
PORT=8000
